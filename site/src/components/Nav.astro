---
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const links = [
  { label: "About", href: `${base}about/` },
  { label: "Docs", href: `${base}docs/` },
];

function isActive(href: string): boolean {
  return currentPath.startsWith(href);
}
---

<nav
  class:list={["nav-bar", { "nav-transparent": transparent }]}
  aria-label="Main navigation"
>
  <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-14">
    <div class="flex items-center gap-2">
      <a href={base} class="font-display text-lg font-semibold text-text hover:text-text no-underline">
        Engram<span class="text-accent">R</span>
      </a>
      <a
        href="https://github.com/achousal/EngramR/releases/tag/v0.7.5"
        class="text-[0.625rem] font-mono font-medium text-accent-dim border border-accent-dim rounded-full px-1.5 py-0.5 leading-none no-underline hover:text-accent hover:border-accent transition-colors"
      >
        v0.7.5
      </a>
    </div>

    {/* Desktop links */}
    <div class="hidden md:flex items-center gap-6">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "text-sm font-medium transition-colors no-underline",
            isActive(link.href)
              ? "text-accent"
              : "text-text-muted hover:text-text",
          ]}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}

      <a
        href="https://github.com/achousal/EngramR"
        class="text-text-muted hover:text-text transition-colors"
        aria-label="GitHub repository"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
    </div>

    {/* Mobile hamburger */}
    <button
      type="button"
      id="mobile-menu-toggle"
      class="md:hidden p-2 -mr-2 text-text-muted hover:text-text transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg class="w-5 h-5 hamburger-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg class="w-5 h-5 close-icon hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  {/* Mobile menu panel */}
  <div id="mobile-menu" class="md:hidden hidden border-t border-border">
    <div class="max-w-6xl mx-auto px-6 py-4 space-y-3">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "mobile-menu-link block text-sm font-medium transition-colors no-underline py-1",
            isActive(link.href)
              ? "text-accent"
              : "text-text-muted hover:text-text",
          ]}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://github.com/achousal/EngramR"
        class="mobile-menu-link block text-sm font-medium text-text-muted hover:text-text transition-colors no-underline py-1"
      >
        GitHub
      </a>
    </div>
  </div>
</nav>

{/* Mobile menu backdrop */}
<div id="mobile-menu-backdrop" class="fixed inset-0 z-30 bg-base/60 backdrop-blur-sm hidden md:hidden"></div>
