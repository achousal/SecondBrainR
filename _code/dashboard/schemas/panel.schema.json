{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://engram-r.dev/schemas/panel.schema.json",
  "title": "Biomarker Panel",
  "description": "Configuration for a biomarker visualization panel",
  "type": "object",
  "required": ["id", "name", "version", "description", "biomarkers"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Unique panel identifier (lowercase, underscores allowed)"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable panel name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version string"
    },
    "description": {
      "type": "string",
      "description": "Panel description for clinicians"
    },
    "biomarkers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Biomarker" },
      "description": "List of biomarker configurations"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "Biomarker": {
      "type": "object",
      "required": ["id", "name", "unit", "aliases", "zones"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Unique biomarker identifier within the panel"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable biomarker name"
        },
        "unit": {
          "type": "string",
          "minLength": 1,
          "description": "Unit of measurement (e.g., pg/mL, ratio, mg/L)"
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Alternative column names for auto-detection"
        },
        "zones": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/Zone" },
          "description": "Classification zones (must be contiguous)"
        },
        "source": {
          "type": "string",
          "description": "Citation for reference ranges"
        },
        "notes": {
          "type": "string",
          "description": "Additional clinical notes"
        }
      },
      "additionalProperties": false
    },
    "Zone": {
      "type": "object",
      "required": ["label", "min", "max", "color", "interpretation"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Zone label (e.g., Normal, Elevated, High)"
        },
        "min": {
          "type": "number",
          "description": "Lower bound (inclusive)"
        },
        "max": {
          "type": "number",
          "description": "Upper bound (exclusive, except for last zone)"
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$",
          "description": "Hex color code"
        },
        "interpretation": {
          "type": "string",
          "description": "Patient-friendly interpretation text"
        }
      },
      "additionalProperties": false
    }
  }
}
