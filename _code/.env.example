# Project-scoped env vars for daemon, Slack bot, and interactive skills.
# Sourced automatically by daemon.sh (set -a) and by literature setup
# (set -a && source _code/.env) during onboarding and /literature --setup.
# No 'export' keyword needed -- set -a handles it.

# Semantic Scholar (optional) -- higher rate limits with key
S2_API_KEY=

# OpenAlex (optional) -- required for production, higher rate limits
OPENALEX_API_KEY=

# Literature enrichment (optional) -- email for CrossRef polite pool + Unpaywall TOS
LITERATURE_ENRICHMENT_EMAIL=

# PubMed / NCBI (optional -- higher rate limits + NCBI policy compliance)
# Interactive use: set in ~/.zshenv_secrets with 'export'
NCBI_API_KEY=
NCBI_EMAIL=

# Slack notifications (optional) -- see docs/manual/setup-guide.md
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_DEFAULT_CHANNEL=C0123456789
SLACK_TEAM_ID=T0123456789

# Slack bot (optional) -- two-way vault-aware assistant via Socket Mode
# Requires Socket Mode enabled on your Slack app + connections:write scope
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# Anthropic API key for Slack bot Claude responses (NOT for interactive Claude Code)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Channel where ALL messages trigger the bot (optional, bot always responds to DMs and @mentions)
SLACK_BOT_CHANNEL=C0123456789
