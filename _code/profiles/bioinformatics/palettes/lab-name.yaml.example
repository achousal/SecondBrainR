# Lab Palette Template
# Copy to {your-lab-name}.yaml and customize.

# First-choice accent colors (1-3 colors for simple plots)
accent:
  primary: "#0072B2"
  secondary: "#E69F00"
  tertiary: "#009E73"

# Categorical palette (8 colors for multi-level variables)
# Common choices: ColorBrewer Set1, Okabe-Ito, or custom
categorical:
  - "#E41A1C"
  - "#377EB8"
  - "#4DAF4A"
  - "#984EA3"
  - "#FF7F00"
  - "#A65628"
  - "#F781BF"
  - "#999999"

# Optional: risk tier colors for interactive dashboards
# risk_tiers:
#   hi:  "rgb(102, 45, 145)"
#   int: "rgb(200, 140, 0)"
#   low: "rgb(56, 150, 80)"
